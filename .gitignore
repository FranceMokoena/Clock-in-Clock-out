# Root .gitignore for Clock-in project

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Environment variables - CRITICAL: Never commit .env files!
.env
.env.local
.env.*.local
*.env

# Temporary files
*.tmp
*.temp
.cache/
tmp/
temp/

# Node modules (if any at root)
node_modules/

# Backup files
*.bak
*.backup
*~

# Documentation build
docs/_build/

# Coverage
coverage/
.nyc_output/

